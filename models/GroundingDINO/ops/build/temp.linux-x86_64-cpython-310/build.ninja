ninja_required_version = 1.3
cxx = g++-9
nvcc = /usr/local/cuda-11.7/bin/nvcc

cflags = -march=nocona -mtune=haswell -ftree-vectorize -fPIC -fstack-protector-strong -fno-plt -O2 -ffunction-sections -pipe -isystem /data1/wangjh/anaconda3/envs/countvid/include -DNDEBUG -D_FORTIFY_SOURCE=2 -O2 -isystem /data1/wangjh/anaconda3/envs/countvid/include -fPIC -DWITH_CUDA -I/data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include/TH -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda-11.7/include -I/data1/wangjh/anaconda3/envs/countvid/include/python3.10 -c
post_cflags = -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -std=c++17
cuda_cflags = -DWITH_CUDA -I/data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include/torch/csrc/api/include -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include/TH -I/data1/wangjh/anaconda3/envs/countvid/lib/python3.10/site-packages/torch/include/THC -I/usr/local/cuda-11.7/include -I/data1/wangjh/anaconda3/envs/countvid/include/python3.10 -c
cuda_post_cflags = -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_BFLOAT16_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ --expt-relaxed-constexpr --compiler-options ''"'"'-fPIC'"'"'' -DCUDA_HAS_FP16=1 -D__CUDA_NO_HALF_OPERATORS__ -D__CUDA_NO_HALF_CONVERSIONS__ -D__CUDA_NO_HALF2_OPERATORS__ -DTORCH_API_INCLUDE_EXTENSION_H '-DPYBIND11_COMPILER_TYPE="_gcc"' '-DPYBIND11_STDLIB="_libstdcpp"' '-DPYBIND11_BUILD_ABI="_cxxabi1011"' -DTORCH_EXTENSION_NAME=MultiScaleDeformableAttention -D_GLIBCXX_USE_CXX11_ABI=0 -gencode=arch=compute_86,code=compute_86 -gencode=arch=compute_86,code=sm_86 -ccbin gcc-9 -std=c++17
cuda_dlink_post_cflags = 
ldflags = 

rule compile
  command = $cxx -MMD -MF $out.d $cflags -c $in -o $out $post_cflags
  depfile = $out.d
  deps = gcc

rule cuda_compile
  depfile = $out.d
  deps = gcc
  command = $nvcc --generate-dependencies-with-compile --dependency-output $out.d $cuda_cflags -c $in -o $out $cuda_post_cflags





build /data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/build/temp.linux-x86_64-cpython-310/data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src/cpu/ms_deform_attn_cpu.o: compile /data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src/cpu/ms_deform_attn_cpu.cpp
build /data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/build/temp.linux-x86_64-cpython-310/data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src/cuda/ms_deform_attn_cuda.o: cuda_compile /data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src/cuda/ms_deform_attn_cuda.cu
build /data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/build/temp.linux-x86_64-cpython-310/data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src/vision.o: compile /data1/wangjh/dataset/CountVid/models/GroundingDINO/ops/src/vision.cpp






